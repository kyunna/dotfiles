{
  {{- if lookPath "peon" }}
  "hooks": {
    "SessionStart": [
      {"matcher": "", "hooks": [{"type": "command", "command": "{{ .chezmoi.homeDir }}/.claude/hooks/peon-ping/peon.sh", "timeout": 10}]}
    ],
    "UserPromptSubmit": [
      {"matcher": "", "hooks": [{"type": "command", "command": "{{ .chezmoi.homeDir }}/.claude/hooks/peon-ping/peon.sh", "timeout": 10}]}
    ],
    "Stop": [
      {"matcher": "", "hooks": [{"type": "command", "command": "{{ .chezmoi.homeDir }}/.claude/hooks/peon-ping/peon.sh", "timeout": 10}]}
    ],
    "Notification": [
      {"matcher": "", "hooks": [{"type": "command", "command": "{{ .chezmoi.homeDir }}/.claude/hooks/peon-ping/peon.sh", "timeout": 10}]}
    ],
    "PermissionRequest": [
      {"matcher": "", "hooks": [{"type": "command", "command": "{{ .chezmoi.homeDir }}/.claude/hooks/peon-ping/peon.sh", "timeout": 10}]}
    ]
  },
  {{- end }}
  "statusLine": {
    "type": "command",
    "command": "bash {{ .chezmoi.homeDir }}/.claude/statusline.sh"
  }
}
