if status is-interactive

    {{ if or (lookPath "nvim") (lookPath "lsd") }}
    ### Editor & Basic Aliases ###
    {{- if lookPath "nvim" }}
    set -gx EDITOR nvim
    alias vim="nvim"
    {{- end }}
    {{- if lookPath "lsd" }}
    alias ls="lsd"
    {{- end }}

    {{- end }}
    {{ if or (and (eq .chezmoi.os "darwin") (lookPath "brew")) (and (eq .chezmoi.os "linux") (lookPath "wslpath")) }}
    ### Platform Specific Settings ###
    {{- if and (eq .chezmoi.os "darwin") (lookPath "brew") }}
    eval "$(/opt/homebrew/bin/brew shellenv)"
    {{- end }}
    {{- if and (eq .chezmoi.os "linux") (lookPath "wslpath") }}
    alias ssh="ssh.exe"
    alias ssh-add="ssh-add.exe"
    {{- end }}

    {{- end }}
    {{ if or (and (eq .chezmoi.os "darwin") (lookPath "brew")) (stat (joinPath .chezmoi.homeDir ".nvm/nvm.sh")) (lookPath "yarn") }}
    ### Node.js Environment ###
    {{- if and (eq .chezmoi.os "darwin") (lookPath "brew") }}
    set -gx NVM_DIR (brew --prefix nvm)
    function nvm
        bass source $NVM_DIR/nvm.sh --no-use ';' nvm $argv
    end
    set --universal nvm_default_version latest
    {{- else if stat (joinPath .chezmoi.homeDir ".nvm/nvm.sh") }}
    set -gx NVM_DIR "$HOME/.nvm"
    function nvm
        bass source $NVM_DIR/nvm.sh --no-use ';' nvm $argv
    end
    set --universal nvm_default_version latest
    {{- end }}
    {{- if lookPath "yarn" }}
    set -gx fish_user_paths (yarn global bin) $fish_user_paths
    {{- end }}

    {{- end }}
    {{ if or (stat (joinPath .chezmoi.homeDir "miniconda3/bin/conda")) (stat (joinPath .chezmoi.homeDir "miniconda3/etc/fish/conf.d/conda.fish")) (stat (joinPath .chezmoi.homeDir "miniconda3/bin")) }}
    ### Conda Environment ###
    {{- if stat (joinPath .chezmoi.homeDir "miniconda3/bin/conda") }}
    eval "{{ .chezmoi.homeDir }}/miniconda3/bin/conda" "shell.fish" "hook" $argv | source
    {{- else if stat (joinPath .chezmoi.homeDir "miniconda3/etc/fish/conf.d/conda.fish") }}
    source "{{ .chezmoi.homeDir }}/miniconda3/etc/fish/conf.d/conda.fish"
    {{- else if stat (joinPath .chezmoi.homeDir "miniconda3/bin") }}
    set -x PATH "{{ .chezmoi.homeDir }}/miniconda3/bin" $PATH
    {{- end }}

    {{- end }}
end
