if status is-interactive
    # Editor configuration
    {{- if lookPath "nvim" }}
    set -gx EDITOR nvim
    {{- end }}

    # Alias configuration
    {{- if lookPath "nvim" }}
    alias vim="nvim"
    {{- end }}
    {{- if lookPath "lsd" }}
    alias ls="lsd"
    {{- end }}
    {{- if and (eq .chezmoi.os "linux") (lookPath "wslpath") }}
    ## WSL specific aliases
    alias ssh="ssh.exe"
    alias ssh-add="ssh-add.exe"
    {{- end }}

    # 1Password SSH agent configuration
    {{- if and (eq .chezmoi.os "darwin") (stat "/Applications/1Password.app") }}
    set -gx SSH_AUTH_SOCK "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
    {{- else if and (eq .chezmoi.os "linux") (not (lookPath "wslpath")) (stat "/opt/1Password/1password") }}
    set -gx SSH_AUTH_SOCK "~/.1password/agent.sock"
    {{- end }}

    # FZF configuration
    {{- if lookPath "fzf" }}
    ## FZF initialization and default options
    fzf --fish | source
    set -gx FZF_DEFAULT_OPTS "--height 40% --layout=reverse --border"
    ## Set FZF_DEFAULT_COMMAND based on available tools
    {{- if lookPath "fd" }}
    set -gx FZF_DEFAULT_COMMAND "fd --type f --hidden --follow --exclude .git"
    {{- end }}
    {{- if lookPath "rg" }}
    set -gx FZF_DEFAULT_COMMAND "rg --files --hidden --follow --glob '!.git'"
    {{- end }}
    {{- end }}


    {{- if and (eq .chezmoi.os "darwin") (lookPath "brew") }}
    # Initialize Homebrew environment
    eval "$(/opt/homebrew/bin/brew shellenv)"
    {{- end }}


    {{- if lookPath "starship" }}
    # Initialize Starship prompt
    starship init fish | source
    {{- end }}
end
